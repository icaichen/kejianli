# keeplix backend 配置。复制为 .env。不填任何 key 也能全链路跑（全 stub）。

# 数据库：默认 SQLite（零外部依赖）。生产用 Postgres：
# KEEPLIX_DATABASE_URL=postgresql+psycopg://keeplix:keeplix@localhost:5432/keeplix
KEEPLIX_DATABASE_URL=sqlite:///./keeplix.db

# CORS 允许的前端来源
KEEPLIX_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Citation 采样默认次数（每 prompt 采样 N 次）
KEEPLIX_CITATION_SAMPLES=3

# 抓取：默认 httpx（快 + 零依赖）。SSR/CSR 客户站点可开浏览器抓取：
#   1) uv sync --extra browser
#   2) uv run playwright install chromium
#   3) KEEPLIX_USE_BROWSER=1
# KEEPLIX_USE_BROWSER=0
# KEEPLIX_FETCH_USER_AGENT=keeplix-bot/0.1

# 模型 API key（有则对应引擎切真实，无则 stub）。示例真实 provider：DeepSeek
# KEEPLIX_DEEPSEEK_API_KEY=sk-xxxx
# KEEPLIX_DEEPSEEK_BASE_URL=https://api.deepseek.com

# 其余引擎接入点（后续补 provider 后启用）：
# KEEPLIX_QWEN_API_KEY=
# KEEPLIX_KIMI_API_KEY=
# KEEPLIX_OPENAI_API_KEY=
# KEEPLIX_PERPLEXITY_API_KEY=
